# =========================
# Python bytecode / caches
# =========================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# =========================
# Python packaging / build
# =========================
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/
.python-version

# =========================
